PORT=5000
NODE_ENV=development

# CHANGE THIS to a long random string before deploying. Used to sign login tokens.
JWT_SECRET=eaa5f1b28d4a56a30dc1d49d5c3a01a3e3777c338f06d06438be9bd2e3952d2b
JWT_EXPIRES_IN=12h

# Comma-separated list of allowed frontend origins, or * for any (only use * during local dev)
CORS_ORIGIN=*

# Default admin password set on first run only (ignored after the admin account exists)
DEFAULT_ADMIN_PASSWORD=Admin@123

# Where the SQLite database file is stored (relative to backend/data by default)
# DB_PATH=/absolute/path/to/supermarket.db
